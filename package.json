{
  "name": "mnemon-mcp",
  "version": "1.3.0",
  "description": "Persistent layered memory MCP server for AI agents — SQLite + FTS5 backend",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mnemon-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "!dist/__benchmarks__/",
    "!dist/**/__tests__/",
    "!dist/.tsbuildinfo",
    "config.example.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "server.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "import:kb": "tsx src/import/cli.ts --kb-path ${MNEMON_KB_PATH:-.}",
    "test": "vitest run",
    "bench": "vitest bench",
    "start:http": "node dist/index-http.js",
    "db:backup": "bash -c \"sqlite3 $HOME/.mnemon-mcp/memory.db '.backup $HOME/.mnemon-mcp/memory.db.bak' && echo 'Backup saved to ~/.mnemon-mcp/memory.db.bak'\"",
    "embed:backfill": "tsx src/import/embed-backfill.ts"
  },
  "keywords": [
    "mcp",
    "memory",
    "sqlite",
    "fts5",
    "ai-agent",
    "model-context-protocol",
    "anthropic",
    "claude",
    "persistent-memory",
    "knowledge-base",
    "multilingual",
    "stemming",
    "local-first",
    "privacy",
    "typescript",
    "cursor",
    "windsurf",
    "layered-memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nikitacometa/mnemon-memory-mcp.git"
  },
  "homepage": "https://aisatisfy.me/mnemon/",
  "bugs": {
    "url": "https://github.com/nikitacometa/mnemon-memory-mcp/issues"
  },
  "types": "dist/index.d.ts",
  "author": "Nikita Gorokhov (https://github.com/nikitacometa)",
  "license": "MIT",
  "mcpName": "io.github.nikitacometa/mnemon-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "snowball-stemmer.jsx": "^0.2.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^9.39.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  }
}
